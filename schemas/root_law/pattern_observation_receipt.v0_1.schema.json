{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PatternObservationReceipt",
  "version": "0.1",
  "description": "Passive Phase 3 receipt for observing repeated structural diagnostic patterns without memory, reputation, quarantine, or authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact",
    "receipt_id",
    "run_id",
    "batch_id",
    "timestamp_utc",
    "corpus_window",
    "reason_code_map_ref",
    "threshold_policy_ref",
    "packet_observations",
    "pattern_results",
    "memory_update",
    "reputation_system",
    "quarantine",
    "authority"
  ],
  "properties": {
    "artifact": {
      "type": "string",
      "const": "pattern_observation_receipt.v0_1"
    },
    "receipt_id": { "type": "string" },
    "run_id": { "type": "string" },
    "batch_id": { "type": "string" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "corpus_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "window_size", "sequence_scope"],
      "properties": {
        "mode": { "type": "string", "const": "last_N_packets" },
        "window_size": { "type": "integer", "minimum": 1 },
        "sequence_scope": { "type": "string", "const": "runner_level_within_declared_test_corpus" }
      }
    },
    "reason_code_map_ref": { "type": "string" },
    "threshold_policy_ref": { "type": "string" },
    "packet_observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "packet_sequence_id",
          "fixture_id",
          "reason_codes",
          "families",
          "pattern_triggers",
          "authority"
        ],
        "properties": {
          "packet_sequence_id": { "type": "integer", "minimum": 1 },
          "fixture_id": { "type": "string" },
          "reason_codes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "families": {
            "type": "array",
            "items": { "type": "string" }
          },
          "pattern_triggers": {
            "type": "array",
            "items": { "type": "boolean" }
          },
          "authority": { "type": "boolean", "const": false }
        }
      }
    },
    "pattern_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pattern_family",
          "observed_count",
          "threshold",
          "pattern_detected",
          "success_masking",
          "authority"
        ],
        "properties": {
          "pattern_family": { "type": "string" },
          "observed_count": { "type": "integer", "minimum": 0 },
          "threshold": { "type": "integer", "minimum": 1 },
          "pattern_detected": { "type": "boolean" },
          "success_masking": { "type": "boolean", "const": false },
          "authority": { "type": "boolean", "const": false }
        }
      }
    },
    "memory_update": { "type": "boolean", "const": false },
    "reputation_system": { "type": "boolean", "const": false },
    "quarantine": { "type": "boolean", "const": false },
    "authority": { "type": "boolean", "const": false }
  }
}
