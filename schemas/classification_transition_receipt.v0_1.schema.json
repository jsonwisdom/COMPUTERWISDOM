{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClassificationTransitionReceipt",
  "description": "Formal record of a category transition within the classification lattice.",
  "type": "object",
  "required": [
    "transition_id",
    "origin_receipt_id",
    "new_receipt_id",
    "from_category",
    "to_category",
    "timestamp_utc",
    "version",
    "authority"
  ],
  "properties": {
    "transition_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "origin_receipt_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "new_receipt_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "from_category": {
      "enum": [
        "ASSERTED",
        "OBSERVED",
        "DERIVED",
        "DISPUTED"
      ]
    },
    "to_category": {
      "enum": [
        "OBSERVED",
        "DERIVED",
        "DISPUTED",
        "ADJUDICATED"
      ]
    },
    "reason_code": {
      "type": "string"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "const": "0.1"
    },
    "authority": {
      "const": false
    }
  },
  "additionalProperties": false
}
