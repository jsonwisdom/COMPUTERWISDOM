{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GLOBAL_GOVERNANCE_ROLE_ANCHOR_V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "anchor_id",
    "as_of",
    "jurisdiction",
    "office",
    "person",
    "role_status",
    "sources",
    "boundary"
  ],
  "properties": {
    "anchor_id": {
      "const": "GLOBAL_GOVERNANCE_ROLE_ANCHOR_V1"
    },
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "jurisdiction": {
      "type": "string",
      "minLength": 1
    },
    "office": {
      "type": "string",
      "minLength": 1
    },
    "person": {
      "type": "string",
      "minLength": 1
    },
    "role_status": {
      "type": "string",
      "enum": [
        "CURRENT_OFFICE_HOLDER",
        "CANDIDATE",
        "NOMINEE",
        "SUCCESSOR_ELECT",
        "FORMER_OFFICE_HOLDER",
        "UNKNOWN"
      ]
    },
    "election_date": {
      "type": "string",
      "format": "date"
    },
    "term_context": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "boundary": {
      "const": "CANDIDATE_NOMINEE_SUCCESSOR_ELECT_NOT_CURRENT_OFFICE_HOLDER"
    }
  }
}
