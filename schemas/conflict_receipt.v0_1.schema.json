{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConflictReceipt",
  "description": "Formal record of a dispute between two or more receipts.",
  "type": "object",
  "required": [
    "conflict_id",
    "conflicting_receipt_ids",
    "conflict_type",
    "timestamp_utc",
    "version",
    "authority"
  ],
  "properties": {
    "conflict_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "conflicting_receipt_ids": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "pattern": "^sha256:[a-f0-9]{64}$"
      }
    },
    "conflict_type": {
      "type": "string"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "const": "0.1"
    },
    "authority": {
      "const": false
    }
  },
  "additionalProperties": false
}
