{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/validator_receipt.v0_1.schema.json",
  "title": "VALIDATOR_RECEIPT_SCHEMA_V0_1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "authority",
    "validator",
    "target_artifact",
    "checks",
    "result"
  ],
  "properties": {
    "artifact_id": {"type": "string"},
    "artifact_type": {"const": "validator_receipt"},
    "authority": {"const": false},
    "validator": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "authority"],
      "properties": {
        "id": {"type": "string"},
        "authority": {"const": false}
      }
    },
    "target_artifact": {
      "type": "object",
      "required": ["path", "hash"],
      "properties": {
        "path": {"type": "string"},
        "hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "passed"],
        "properties": {
          "name": {"type": "string"},
          "passed": {"type": "boolean"},
          "details": {"type": "string"}
        }
      }
    },
    "result": {
      "type": "string",
      "enum": ["MATCH_CONFIRMED", "DIVERGENCE_DETECTED", "INVALID"]
    }
  }
}
