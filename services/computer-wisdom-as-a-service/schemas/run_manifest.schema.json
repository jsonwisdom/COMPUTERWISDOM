{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CWaaS Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["service", "mode", "posture_state", "run_id", "run_dir", "started_at", "updated_at", "mutation_allowed", "outputs_are_candidates_until_replayed", "authority", "no_fake_green"],
  "properties": {
    "service": {"const": "COMPUTER_WISDOM_AS_A_SERVICE"},
    "mode": {"const": "READ_ONLY_COLLECTION"},
    "posture_state": {"enum": ["BLOCKED", "COLLECTION_RUNNING", "DUMPS_PRESERVED", "FAILED", "MISSING_RECEIPT", "STALE", "CANDIDATE_REPORTED", "CLIENT_REPLAYED"]},
    "reason": {"type": "string"},
    "run_id": {"type": "string", "minLength": 1},
    "run_dir": {"type": "string", "minLength": 1},
    "started_at": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "minLength": 1},
    "completed_at": {"type": "string"},
    "mutation_allowed": {"const": false},
    "outputs_are_candidates_until_replayed": {"const": true},
    "authority": {"const": false},
    "no_fake_green": {"const": true}
  }
}
