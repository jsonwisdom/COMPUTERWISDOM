{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest.schema.json",
  "title": "Receipt Replay Manifest",
  "type": "object",
  "required": ["schema", "files"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "receipt-manifest-v1"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "digest", "type", "timestamp"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "type": {
            "type": "string",
            "enum": ["artifact", "governance", "map", "schema", "verifier"]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
