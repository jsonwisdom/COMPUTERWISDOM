{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jsonwisdom/COMPUTERWISDOM/docs/protocols/manic/schemas/replay_node.v1.schema.json",
  "title": "MANIC Replay Node v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_id",
    "parent_root_id",
    "parent_hash",
    "source_locator",
    "transform_id",
    "content_hash",
    "constitutional_tags"
  ],
  "properties": {
    "node_id": {
      "type": "string",
      "pattern": "^RPL-\\d{3}-[A-Z0-9]+-\\d{5}$"
    },
    "parent_root_id": {
      "type": "string",
      "pattern": "^ROOT_SOURCE_[A-Z0-9_]+$"
    },
    "parent_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_locator": {
      "type": "object",
      "minProperties": 1
    },
    "source_offset_start": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "source_offset_end": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "transform_id": {
      "type": "string",
      "enum": [
        "STRUCTURAL_SPLIT",
        "CONTENT_HASH",
        "LOCATOR_CAPTURE",
        "SCHEMA_VALIDATE"
      ]
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "constitutional_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["OBSERVED"]
      },
      "contains": {
        "const": "OBSERVED"
      }
    },
    "governing_invariant": {
      "type": "string"
    }
  }
}
