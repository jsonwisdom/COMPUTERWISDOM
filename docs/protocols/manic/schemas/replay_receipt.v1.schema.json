{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jsonwisdom/COMPUTERWISDOM/docs/protocols/manic/schemas/replay_receipt.v1.schema.json",
  "title": "MANIC Replay Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "receipt_id",
    "created_at",
    "protocol",
    "protocol_version",
    "replay_cycle",
    "root_source",
    "validator_set",
    "replay_nodes",
    "result_code",
    "continuity_flag",
    "authority_claim",
    "truth_adjudication"
  ],
  "properties": {
    "schema_id": { "const": "MANIC_REPLAY_RECEIPT_V1" },
    "receipt_id": { "type": "string", "pattern": "^replay_receipt:[a-f0-9]{64}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "protocol": { "const": "MANIC" },
    "protocol_version": { "type": "string", "pattern": "^0\\.1$" },
    "replay_cycle": { "type": "string", "minLength": 1 },
    "root_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_id", "receipt_id", "source_type"],
      "properties": {
        "root_id": { "type": "string", "pattern": "^ROOT_SOURCE_[A-Z0-9_]+$" },
        "receipt_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "source_type": { "type": "string", "minLength": 1 }
      }
    },
    "validator_set": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "commit_sha"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "commit_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
        }
      }
    },
    "replay_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "path", "commit_sha", "result"],
        "properties": {
          "node_id": { "type": "string", "pattern": "^RPL-\\d{3}-[A-Z0-9]+-\\d{5}$" },
          "path": { "type": "string", "minLength": 1 },
          "commit_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
          "result": { "type": "string", "enum": ["PASSED", "FAILED", "REFUSED"] }
        }
      }
    },
    "result_code": {
      "type": "string",
      "enum": [
        "REPLAY_VALIDATED",
        "DRIFT_DETECTED",
        "NON_DETERMINISTIC_OUTPUT",
        "MISSING_LINEAGE",
        "UNAUTHORIZED_TRANSFORM",
        "INCOMPLETE_RECEIPT",
        "OFFSET_UNAVAILABLE",
        "INTERPRETATION_ATTEMPTED"
      ]
    },
    "continuity_flag": { "const": "COHERENTLY_INVALID_UNTIL_REPLAYED" },
    "authority_claim": { "const": "NONE" },
    "truth_adjudication": { "const": "NOT_PERFORMED" }
  }
}
