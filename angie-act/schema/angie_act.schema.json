{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ANGIE Act Public Scorecard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "bill_or_action",
    "member",
    "entity_x",
    "date_submitted",
    "overall_verdict",
    "amy_flag",
    "audit_notes",
    "filters",
    "source_links"
  ],
  "properties": {
    "claim_id": {"type": "string", "minLength": 1},
    "bill_or_action": {"type": "string", "minLength": 1},
    "member": {"type": "string", "minLength": 1},
    "entity_x": {"type": "string", "minLength": 1},
    "date_submitted": {"type": "string", "format": "date"},
    "overall_verdict": {
      "type": "string",
      "enum": ["clean", "watch", "plausible_not_proven", "influence_flagged"]
    },
    "amy_flag": {"type": "boolean"},
    "audit_notes": {"type": "string"},
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alignment", "norm", "gain", "integrity", "evidence"],
      "properties": {
        "alignment": {"$ref": "#/definitions/scored_filter"},
        "norm": {"$ref": "#/definitions/scored_filter"},
        "gain": {"$ref": "#/definitions/scored_filter"},
        "integrity": {"$ref": "#/definitions/scored_filter"},
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["score", "explanation", "claim_type", "sources_used"],
          "properties": {
            "score": {"type": "integer", "minimum": 0, "maximum": 2},
            "explanation": {"type": "string"},
            "claim_type": {
              "type": "string",
              "enum": ["federal", "minnesota_state", "ie", "lobbying", "disclosure"]
            },
            "sources_used": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "source_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_name", "url", "accessed_date"],
        "properties": {
          "source_name": {"type": "string", "minLength": 1},
          "url": {"type": "string", "format": "uri"},
          "accessed_date": {"type": "string", "format": "date"}
        }
      }
    }
  },
  "definitions": {
    "scored_filter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "explanation"],
      "properties": {
        "score": {"type": "integer", "minimum": 0, "maximum": 2},
        "explanation": {"type": "string"}
      }
    }
  }
}
